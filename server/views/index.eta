<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>IRONSAIT — Админ Панель</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body {
      background: radial-gradient(circle at 10% 20%, #0b1120 0%, #0f172a 90%);
      color: #e2e8f0;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      margin: 0;
    }

    .glass-panel {
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(71, 85, 105, 0.25);
      box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.6);
    }

    .card-dynamic {
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.9) 0%, rgba(15, 23, 42, 0.95) 100%);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(99, 179, 237, 0.15);
      box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.7);
      transition: all 0.25s ease;
    }

    .card-dynamic:hover {
      border-color: rgba(56, 189, 248, 0.35);
      box-shadow: 0 25px 45px -10px rgba(14, 165, 233, 0.2);
      transform: translateY(-2px);
    }

    .btn-primary {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      border: 1px solid rgba(96, 165, 250, 0.4);
      box-shadow: 0 10px 20px -8px rgba(37, 99, 235, 0.5);
      transition: all 0.2s ease-in-out;
      letter-spacing: 0.3px;
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      box-shadow: 0 15px 25px -8px #2563eb80;
      transform: scale(1.02);
    }

    .nav-item {
      transition: all 0.2s ease;
      border-left: 3px solid transparent;
      border-radius: 12px;
      margin-bottom: 6px;
      background: rgba(255, 255, 255, 0.02);
    }

    .nav-item:hover {
      background: rgba(56, 189, 248, 0.1);
      border-left: 3px solid #38bdf8;
      padding-left: 20px;
    }

    .table-custom th {
      font-weight: 500;
      letter-spacing: 0.5px;
      color: #94a3b8;
      background: rgba(15, 23, 42, 0.6);
    }

    .table-custom td {
      border-bottom: 1px solid rgba(71, 85, 105, 0.25);
      padding: 16px 8px;
      vertical-align: middle;
    }

    .table-custom tr:last-child td {
      border-bottom: none;
    }

    .delete-btn {
      background: rgba(239, 68, 68, 0.1);
      padding: 8px 16px;
      border-radius: 30px;
      color: #fecaca;
      font-weight: 500;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .delete-btn:hover {
      background: rgba(239, 68, 68, 0.3);
      color: white;
      border-color: #ef4444;
    }

    .custom-scroll::-webkit-scrollbar {
      width: 6px;
    }
    .custom-scroll::-webkit-scrollbar-track {
      background: #0f172a;
    }
    .custom-scroll::-webkit-scrollbar-thumb {
      background: #334155;
      border-radius: 8px;
    }

    input, textarea {
      transition: 0.2s ease;
      border: 1px solid #334155;
      outline: none;
      background: #0f172a;
    }

    input:focus, textarea:focus {
      border-color: #38bdf8;
      box-shadow: 0 0 15px rgba(56, 189, 248, 0.25);
      background: #1e293b;
    }

    .badge-id {
      background: #1e293b;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.8rem;
      color: #b9c7dd;
    }

    img.thumbnail {
      border-radius: 14px;
      box-shadow: 0 8px 14px rgba(0,0,0,0.5);
      border: 1px solid #475569;
      width: 56px;
      height: 56px;
      object-fit: cover;
    }

    .loading-spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 50%;
      border-top-color: #fff;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .toast {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 12px 24px;
      border-radius: 12px;
      color: white;
      font-weight: 500;
      z-index: 1000;
      animation: slideIn 0.3s ease;
    }

    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }

    .toast-success { background: #059669; }
    .toast-error { background: #dc2626; }
  </style>
</head>
<body class="min-h-screen flex">

<!-- SIDEBAR -->
<div class="w-72 glass-panel flex flex-col p-6 m-4 rounded-3xl shadow-2xl">
  <div class="flex items-center gap-3 mb-12">
    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/30">
      <i class="fas fa-cube text-white text-xl"></i>
    </div>
    <h1 class="text-2xl font-extrabold tracking-tight bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">IRONSAIT</h1>
  </div>

  <nav class="flex flex-col gap-1 flex-1">
    <button onclick="showTab(1)" class="nav-item w-full text-left px-5 py-3.5 rounded-xl flex items-center gap-3 text-slate-300 font-medium">
      <i class="fas fa-tools w-5 text-blue-400"></i> Услуги
    </button>
    <button onclick="showTab(2)" class="nav-item w-full text-left px-5 py-3.5 rounded-xl flex items-center gap-3 text-slate-300 font-medium">
      <i class="fas fa-images w-5 text-emerald-400"></i> Примеры работ
    </button>
    <button onclick="showTab(3)" class="nav-item w-full text-left px-5 py-3.5 rounded-xl flex items-center gap-3 text-slate-300 font-medium">
      <i class="fas fa-clipboard-list w-5 text-amber-400"></i> Заявки
    </button>
    <button onclick="showTab(4)" class="nav-item w-full text-left px-5 py-3.5 rounded-xl flex items-center gap-3 text-slate-300 font-medium">
      <i class="fas fa-chart-line w-5 text-rose-400"></i> Мониторинг
    </button>
  </nav>

  <div class="mt-auto pt-6 border-t border-slate-700/50">
    <a href="/logout" class="flex items-center gap-2 text-slate-400 hover:text-red-400 transition px-4 py-3 rounded-xl hover:bg-red-500/10">
      <i class="fas fa-sign-out-alt"></i> <span>Выйти</span>
    </a>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="flex-1 p-6 ml-2 overflow-auto custom-scroll">
  <div class="flex justify-between items-center mb-10 mt-2">
    <div>
      <h1 class="text-4xl font-bold bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent">Админ Панель</h1>
      <p class="text-slate-400 mt-1 text-sm">Управление контентом сайта</p>
    </div>
    <div class="bg-slate-800/60 px-5 py-3 rounded-2xl border border-slate-700/50">
      <i class="far fa-user-circle text-blue-400 mr-2"></i>
      <span class="text-slate-300 font-medium">Администратор</span>
    </div>
  </div>

  <!-- TAB 1: УСЛУГИ -->
  <div id="tab1" class="tab">
    <div class="card-dynamic rounded-3xl p-7 mb-8">
      <h2 class="text-2xl font-semibold flex items-center gap-3 mb-6">
        <span class="w-8 h-8 bg-blue-600/30 rounded-lg flex items-center justify-center"><i class="fas fa-plus text-blue-300 text-sm"></i></span>
        Добавить услугу
      </h2>
      <form id="serviceForm" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <input type="text" name="name" placeholder="Название услуги" class="bg-slate-900/80 p-4 rounded-xl text-white" required>
        <textarea name="description" placeholder="Описание услуги" class="bg-slate-900/80 p-4 rounded-xl text-white" required></textarea>
        <div class="flex flex-col gap-3">
          <input type="file" name="image" accept="image/*" class="bg-slate-900/80 p-4 rounded-xl text-slate-300 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:bg-blue-600 file:text-white file:border-0">
          <button type="submit" class="btn-primary py-4 rounded-xl font-bold text-white flex items-center justify-center gap-2">
            <i class="fas fa-save"></i> Добавить
          </button>
        </div>
      </form>
    </div>
    <div class="card-dynamic rounded-3xl p-7" id="servicesList">
      <div class="text-slate-400 text-center py-10">
        <div class="loading-spinner mx-auto mb-3"></div>
        Загрузка услуг...
      </div>
    </div>
  </div>

  <!-- TAB 2: ПРИМЕРЫ -->
  <div id="tab2" class="tab hidden">
    <div class="card-dynamic rounded-3xl p-7 mb-8">
      <h2 class="text-2xl font-semibold flex items-center gap-3 mb-6">
        <span class="w-8 h-8 bg-emerald-600/30 rounded-lg flex items-center justify-center"><i class="fas fa-image text-emerald-300 text-sm"></i></span>
        Добавить пример работы
      </h2>
      <form id="exampleForm" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <textarea name="description" placeholder="Описание примера" class="bg-slate-900/80 p-4 rounded-xl text-white" required></textarea>
        <div class="flex flex-col gap-3">
          <input type="file" name="image" accept="image/*" class="bg-slate-900/80 p-4 rounded-xl text-slate-300 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:bg-emerald-600 file:text-white file:border-0">
          <button type="submit" class="btn-primary py-4 rounded-xl font-bold text-white flex items-center justify-center gap-2" style="background:linear-gradient(135deg,#059669,#047857);">
            <i class="fas fa-cloud-upload-alt"></i> Добавить
          </button>
        </div>
      </form>
    </div>
    <div class="card-dynamic rounded-3xl p-7" id="examplesList">
      <div class="text-slate-400 text-center py-10">
        <div class="loading-spinner mx-auto mb-3"></div>
        Загрузка примеров...
      </div>
    </div>
  </div>

  <!-- TAB 3: ЗАЯВКИ -->
  <div id="tab3" class="tab hidden">
    <div class="card-dynamic rounded-3xl p-7" id="bidsList">
      <div class="text-slate-400 text-center py-10">
        <div class="loading-spinner mx-auto mb-3"></div>
        Загрузка заявок...
      </div>
    </div>
  </div>

  <!-- TAB 4: МОНИТОРИНГ -->
  <div id="tab4" class="tab hidden">
    <div class="card-dynamic rounded-3xl p-7">
      <h2 class="text-2xl font-semibold flex items-center gap-3 mb-6">
        <span class="w-8 h-8 bg-rose-600/30 rounded-lg flex items-center justify-center"><i class="fas fa-terminal text-rose-300 text-sm"></i></span>
        Логи системы
      </h2>
      <div id="monitorLogs" class="bg-slate-900/80 rounded-2xl p-5 font-mono text-sm text-slate-300 overflow-auto max-h-96 custom-scroll whitespace-pre-wrap">
        <div class="loading-spinner mx-auto mb-3"></div>
        Загрузка логов...
      </div>
      <div class="mt-4 flex gap-3">
        <button onclick="loadMonitor()" class="bg-blue-600/30 hover:bg-blue-600/50 text-blue-300 px-5 py-2 rounded-xl border border-blue-600/30 transition">
          <i class="fas fa-sync-alt"></i> Обновить
        </button>
        <a href="/admin/monitor" target="_blank" class="bg-slate-700/30 hover:bg-slate-700/50 text-slate-300 px-5 py-2 rounded-xl border border-slate-600/30 transition">
          <i class="fas fa-external-link-alt"></i> Открыть отдельно
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // ===== УТИЛИТЫ =====
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity 0.3s';
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  // ===== ПОКАЗ ВКЛАДКИ =====
  function showTab(n) {
    document.querySelectorAll('.tab').forEach(tab => tab.classList.add('hidden'));
    const activeTab = document.getElementById('tab' + n);
    if (activeTab) {
      activeTab.classList.remove('hidden');
      // Автообновление при переключении
      if (n === 4) loadMonitor();
    }
  }

  // ===== ЗАГРУЗКА ДАННЫХ =====
  async function loadData() {
    try {
      const [services, examples, bids] = await Promise.all([
        fetch('/admin/services').then(r => {
          if (!r.ok) throw new Error(`Services API error: ${r.status}`);
          return r.json();
        }),
        fetch('/admin/examples').then(r => {
          if (!r.ok) throw new Error(`Examples API error: ${r.status}`);
          return r.json();
        }),
        fetch('/admin/bids').then(r => {
          if (!r.ok) throw new Error(`Bids API error: ${r.status}`);
          return r.json();
        })
      ]);
      
      renderServices(services);
      renderExamples(examples);
      renderBids(bids);
    } catch (err) {
      console.error('Ошибка загрузки данных:', err);
      showToast('Ошибка загрузки данных: ' + err.message, 'error');
    }
  }

  // ===== ЗАГРУЗКА МОНИТОРИНГА =====
  async function loadMonitor() {
    const monitorLogs = document.getElementById('monitorLogs');
    monitorLogs.innerHTML = '<div class="loading-spinner mx-auto mb-3"></div> Загрузка логов...';
    
    try {
      const res = await fetch('/admin/monitor');
      
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}: ${res.statusText}`);
      }
      
      const contentType = res.headers.get('content-type');
      
      if (contentType && contentType.includes('text/html')) {
        const html = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const logs = doc.querySelector('pre')?.textContent || 
                     doc.querySelector('body')?.textContent || 
                     'Логи не найдены на странице';
        monitorLogs.textContent = logs;
      } else if (contentType && contentType.includes('application/json')) {
        const data = await res.json();
        monitorLogs.textContent = JSON.stringify(data, null, 2);
      } else {
        const text = await res.text();
        monitorLogs.textContent = text || 'Пустой ответ от сервера';
      }
    } catch (err) {
      monitorLogs.textContent = 'Ошибка загрузки логов: ' + err.message;
      console.error('Ошибка мониторинга:', err);
    }
  }

  // ===== РЕНДЕР УСЛУГ =====
  function renderServices(data) {
    const container = document.getElementById('servicesList');
    
    if (!data || !Array.isArray(data) || data.length === 0) {
      container.innerHTML = '<div class="text-slate-400 text-center py-10">Нет услуг для отображения</div>';
      return;
    }
    
    let html = `
      <table class="w-full table-custom">
        <thead>
          <tr>
            <th class="text-left py-4 pl-2">ID</th>
            <th>Название</th>
            <th>Описание</th>
            <th>Фото</th>
            <th class="text-center">Действия</th>
          </tr>
        </thead>
        <tbody>
    `;
    
    data.forEach(item => {
      const imgHtml = item.imgLink 
        ? `<img src="${escapeHtml(item.imgLink)}" class="thumbnail" alt="service" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"> <span style="display:none;" class="text-slate-600">—</span>` 
        : '<span class="text-slate-600">—</span>';
        
      html += `
        <tr>
          <td class="py-4"><span class="badge-id">#${item.id || '—'}</span></td>
          <td class="font-medium text-white">${escapeHtml(item.name) || '—'}</td>
          <td class="text-slate-400 max-w-[200px] truncate" title="${escapeHtml(item.description || '')}">${escapeHtml(item.description) || '—'}</td>
          <td>${imgHtml}</td>
          <td class="text-center">
            <button onclick="deleteItem('service', ${item.id})" class="delete-btn">
              <i class="fas fa-trash-alt"></i> Удалить
            </button>
          </td>
        </tr>
      `;
    });
    
    html += '</tbody></table>';
    container.innerHTML = html;
  }

  // ===== РЕНДЕР ПРИМЕРОВ =====
  function renderExamples(data) {
    const container = document.getElementById('examplesList');
    
    if (!data || !Array.isArray(data) || data.length === 0) {
      container.innerHTML = '<div class="text-slate-400 text-center py-10">Нет примеров для отображения</div>';
      return;
    }
    
    let html = `
      <table class="w-full table-custom">
        <thead>
          <tr>
            <th class="text-left py-4 pl-2">ID</th>
            <th>Описание</th>
            <th>Фото</th>
            <th class="text-center">Действия</th>
          </tr>
        </thead>
        <tbody>
    `;
    
    data.forEach(item => {
      const imgHtml = item.imgLink 
        ? `<img src="${escapeHtml(item.imgLink)}" class="thumbnail" alt="example" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"> <span style="display:none;" class="text-slate-600">—</span>` 
        : '<span class="text-slate-600">—</span>';
        
      html += `
        <tr>
          <td class="py-4"><span class="badge-id">#${item.id || '—'}</span></td>
          <td class="text-slate-300 max-w-[200px] truncate" title="${escapeHtml(item.description || '')}">${escapeHtml(item.description) || '—'}</td>
          <td>${imgHtml}</td>
          <td class="text-center">
            <button onclick="deleteItem('example', ${item.id})" class="delete-btn">
              <i class="fas fa-trash-alt"></i> Удалить
            </button>
          </td>
        </tr>
      `;
    });
    
    html += '</tbody></table>';
    container.innerHTML = html;
  }

  // ===== РЕНДЕР ЗАЯВОК =====
  function renderBids(data) {
    const container = document.getElementById('bidsList');
    
    if (!data || !Array.isArray(data) || data.length === 0) {
      container.innerHTML = '<div class="text-slate-400 text-center py-10">Нет заявок для отображения</div>';
      return;
    }
    
    let html = `
      <table class="w-full table-custom">
        <thead>
          <tr>
            <th>ID</th>
            <th>Имя</th>
            <th>Контакт</th>
            <th>Статус</th>
            <th>Комментарий</th>
            <th class="text-center">Действия</th>
          </tr>
        </thead>
        <tbody>
    `;
    
    data.forEach(item => {
      const statusClass = item.status === 'new' 
        ? 'bg-amber-500/20 text-amber-300' 
        : 'bg-green-500/20 text-green-300';
      
      html += `
        <tr>
          <td><span class="badge-id">#${item.id || '—'}</span></td>
          <td class="font-medium">${escapeHtml(item.name) || '—'}</td>
          <td class="text-blue-300">${escapeHtml(item.email || item.phone) || '—'}</td>
          <td><span class="px-3 py-1 rounded-full text-xs ${statusClass}">${escapeHtml(item.status) || 'new'}</span></td>
          <td class="text-slate-400 max-w-[180px] truncate" title="${escapeHtml(item.description || '')}">${escapeHtml(item.description) || '—'}</td>
          <td class="text-center">
            <button onclick="deleteItem('bid', ${item.id})" class="delete-btn">
              <i class="fas fa-trash-alt"></i> Удалить
            </button>
          </td>
        </tr>
      `;
    });
    
    html += '</tbody></table>';
    container.innerHTML = html;
  }

  // ===== УДАЛЕНИЕ (ИСПРАВЛЕНО) =====
  async function deleteItem(type, id) {
    if (!confirm(`Вы уверены, что хотите удалить запись #${id}?`)) return;
    
    // Правильное сопоставление типов с API эндпоинтами
    const endpoints = {
      'service': 'services',
      'example': 'examples',
      'bid': 'bids'
    };
    
    const endpoint = endpoints[type];
    
    if (!endpoint) {
      console.error('Неизвестный тип:', type);
      showToast('Ошибка: неизвестный тип данных', 'error');
      return;
    }
    
    try {
      const res = await fetch(`/admin/${endpoint}/${id}`, {
        method: 'DELETE',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      
      if (res.ok) {
        showToast(`Запись #${id} успешно удалена`, 'success');
        await loadData(); // Перезагружаем данные
      } else {
        const errorText = await res.text();
        console.error('Ошибка удаления:', errorText);
        showToast('Ошибка удаления: ' + (errorText || res.statusText), 'error');
      }
    } catch (err) {
      console.error('Ошибка сети:', err);
      showToast('Ошибка сети при удалении', 'error');
    }
  }

  // ===== ФОРМА УСЛУГ =====
  document.getElementById('serviceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    
    // Показываем загрузку
    submitBtn.innerHTML = '<div class="loading-spinner"></div> Добавление...';
    submitBtn.disabled = true;
    
    try {
      const formData = new FormData(form);
      const res = await fetch('/admin/services', {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      
      if (res.ok) {
        form.reset();
        showToast('Услуга успешно добавлена', 'success');
        await loadData();
      } else {
        const errorText = await res.text();
        console.error('Ошибка добавления:', errorText);
        showToast('Ошибка добавления услуги', 'error');
      }
    } catch (err) {
      console.error('Ошибка сети:', err);
      showToast('Ошибка сети при добавлении', 'error');
    } finally {
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
    }
  });

  // ===== ФОРМА ПРИМЕРОВ =====
  document.getElementById('exampleForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    
    // Показываем загрузку
    submitBtn.innerHTML = '<div class="loading-spinner"></div> Добавление...';
    submitBtn.disabled = true;
    
    try {
      const formData = new FormData(form);
      const res = await fetch('/admin/examples', {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      
      if (res.ok) {
        form.reset();
        showToast('Пример успешно добавлен', 'success');
        await loadData();
      } else {
        const errorText = await res.text();
        console.error('Ошибка добавления:', errorText);
        showToast('Ошибка добавления примера', 'error');
      }
    } catch (err) {
      console.error('Ошибка сети:', err);
      showToast('Ошибка сети при добавлении', 'error');
    } finally {
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
    }
  });

  // ===== ИНИЦИАЛИЗАЦИЯ =====
  document.addEventListener('DOMContentLoaded', () => {
    loadData();
    loadMonitor();
    
    // Добавляем обработчики для навигации
    document.querySelectorAll('.nav-item').forEach(btn => {
      btn.addEventListener('click', function() {
        // Убираем активный класс у всех
        document.querySelectorAll('.nav-item').forEach(b => {
          b.style.background = 'rgba(255, 255, 255, 0.02)';
          b.style.borderLeft = '3px solid transparent';
        });
        // Добавляем активный класс текущей
        this.style.background = 'rgba(56, 189, 248, 0.15)';
        this.style.borderLeft = '3px solid #38bdf8';
      });
    });
  });
</script>
</body>
</html>