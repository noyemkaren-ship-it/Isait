<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вход — Админ панель</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-950 to-zinc-900 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-zinc-900 p-10 rounded-3xl shadow-2xl border border-zinc-700">
      
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-white mb-2">🔐 Вход</h1>
        <p class="text-zinc-400">Только для администратора</p>
      </div>

      <form action="/login" method="POST" class="space-y-6">
        <div>
          <input type="text" name="username" placeholder="Логин" required
                 class="w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 text-white placeholder-zinc-500 focus:outline-none focus:border-indigo-500 transition">
        </div>
        <div>
          <input type="password" name="password" placeholder="Пароль" required
                 class="w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 text-white placeholder-zinc-500 focus:outline-none focus:border-indigo-500 transition">
        </div>

        <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-700 py-4 rounded-2xl text-white font-semibold text-lg transition-all active:scale-95">
          Войти
        </button>
      </form>
    </div>
  </div>
</body>
</html>